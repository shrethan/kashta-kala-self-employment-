<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Material Estimator"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/wood_dark"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter furniture dimensions for instant cost estimate"
            android:textSize="13sp"
            android:textColor="@color/wood_muted"
            android:layout_marginBottom="16dp"/>

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Length & Width Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="LENGTH (ft) *" android:textSize="11sp" android:textColor="@color/wood_amber"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_length"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 6"
                            android:inputType="numberDecimal"
                            android:background="@drawable/bg_input"
                            android:padding="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WIDTH (ft) *" android:textSize="11sp" android:textColor="@color/wood_amber"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_width"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 3"
                            android:inputType="numberDecimal"
                            android:background="@drawable/bg_input"
                            android:padding="12dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginVertical="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HEIGHT (ft) — optional" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_height"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 2 (for cubic volume)"
                    android:inputType="numberDecimal"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WOOD TYPE *" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <Spinner
                    android:id="@+id/spinner_wood_type"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_wood_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_wood_info"
                    android:padding="10dp"
                    android:textSize="12sp"
                    android:textColor="@color/wood_mid"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LABOUR RATE (₹/sqft)" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_labor_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Default: 200"
                    android:text="200"
                    android:inputType="number"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button
                        android:id="@+id/btn_calculate"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="2"
                        android:text="📊 Calculate"
                        android:backgroundTint="@color/wood_amber"
                        android:textColor="@android:color/white"
                        android:layout_marginEnd="8dp"/>
                    <Button
                        android:id="@+id/btn_reset"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Reset"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="@color/wood_amber"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Result Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/wood_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✅ Estimate Result"
                    android:textColor="@color/wood_gold" android:textSize="16sp" android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Result Rows -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Wood Type" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_result_wood_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Wood Rate" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_result_rate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Surface Area" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_result_sq_ft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/row_cu_ft" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp" android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Volume" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_result_cu_ft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Wood Cost" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_result_wood_cost" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Labour Cost" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_result_labor_cost" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33f5c87a" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TOTAL ESTIMATE" android:textColor="#99fdf3e3" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_result_total" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/wood_gold" android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
