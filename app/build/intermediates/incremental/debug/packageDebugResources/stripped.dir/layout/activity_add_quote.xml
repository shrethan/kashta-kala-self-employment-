<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_light">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Customer Details" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/wood_dark" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CUSTOMER NAME *" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/et_customer_name" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="e.g. Ramesh Kumar" android:background="@drawable/bg_input" android:padding="12dp"
                    android:inputType="textPersonName" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DESIGN / FURNITURE NAME *" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/et_design_name" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="e.g. King Size Bed" android:background="@drawable/bg_input" android:padding="12dp"
                    android:inputType="textCapWords" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WOOD TYPE *" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinner_wood_type" android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_input" android:layout_marginBottom="12dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginVertical="4dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Dimensions" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/wood_dark" android:layout_marginTop="8dp" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="LENGTH (ft) *" android:textSize="11sp" android:textColor="@color/wood_amber"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/et_length" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:hint="6" android:background="@drawable/bg_input" android:padding="12dp" android:inputType="numberDecimal"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WIDTH (ft) *" android:textSize="11sp" android:textColor="@color/wood_amber"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/et_width" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:hint="4" android:background="@drawable/bg_input" android:padding="12dp" android:inputType="numberDecimal"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HEIGHT (ft) — optional" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginTop="12dp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/et_height" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="2" android:background="@drawable/bg_input" android:padding="12dp" android:inputType="numberDecimal"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="NOTES" android:textSize="11sp" android:textColor="@color/wood_amber"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/et_notes" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Any special requirements..." android:background="@drawable/bg_input" android:padding="12dp"
                    android:inputType="textMultiLine" android:minLines="2" android:layout_marginBottom="16dp"/>

                <Button android:id="@+id/btn_preview"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="👁 Preview Estimate"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/wood_amber"
                    app:strokeColor="@color/wood_amber"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Preview Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/wood_dark">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊 Estimate Preview" android:textColor="@color/wood_gold" android:textSize="14sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Area" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_preview_sq_ft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Wood" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_preview_wood_cost" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Labour" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_preview_labor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TOTAL" android:textColor="#99fdf3e3"/>
                    <TextView android:id="@+id/tv_preview_total" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/wood_gold" android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button android:id="@+id/btn_save_quote"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾 Save Quote"
            android:backgroundTint="@color/wood_amber"
            android:textColor="@android:color/white"
            android:textSize="15sp"/>
    </LinearLayout>
</ScrollView>
