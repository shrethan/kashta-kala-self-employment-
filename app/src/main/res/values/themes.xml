<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KashtaKala" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/wood_amber</item>
        <item name="colorPrimaryVariant">@color/wood_mid</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/wood_gold</item>
        <item name="colorOnSecondary">@color/wood_dark</item>
        <item name="android:colorBackground">@color/bg_cream</item>
        <item name="android:statusBarColor">@color/wood_dark</item>
        <item name="android:navigationBarColor">@color/wood_dark</item>
        <item name="actionBarStyle">@style/KashtaActionBar</item>
    </style>

    <style name="KashtaActionBar" parent="Widget.MaterialComponents.ActionBar.Solid">
        <item name="background">@color/wood_dark</item>
        <item name="titleTextStyle">@style/KashtaActionBarTitle</item>
    </style>

    <style name="KashtaActionBarTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@color/wood_gold</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>
